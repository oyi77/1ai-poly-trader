        "NODE_ENV": "production",
        "PORT": "8100"
      }
    },
    {
      "name": "polyedge-frontend",
      "script": "npm",
      "args": "run dev",
      "cwd": "/home/openclaw/projects/polyedge/frontend",
      "instances": 1,
      "exec_mode": "fork",
      "autorestart": true,
      "watch": false,
      "max_memory_restart": "500M",
      "env": {
        "NODE_ENV": "development"
      }
    }
  ]
}
