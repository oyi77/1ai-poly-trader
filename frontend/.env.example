# Frontend environment variables
# Copy to .env.local

# Backend API URL (required for production)
# For local development: http://localhost:8000
# For production: https://your-railway-app.up.railway.app
VITE_API_URL=http://localhost:8000

# Mapbox token for map visualization
# Get yours free at: https://account.mapbox.com/
VITE_MAPBOX_TOKEN=

# Signal notification settings
# How long signal popups stay visible (milliseconds)
# Default: 10000 (10 seconds)
VITE_SIGNAL_NOTIFICATION_DURATION=10000

# Signal approval mode: "manual", "auto_approve", "auto_deny"
# manual: always show popup for user approval (default)
# auto_approve: auto-approve signals above 85% confidence
# auto_deny: auto-deny all signals
VITE_SIGNAL_APPROVAL_MODE=manual
